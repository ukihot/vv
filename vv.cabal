cabal-version:      3.4
name:               vv
version:            0.1.0.0
synopsis:           IFRS-based double-entry financial accounting system
description:
    A modern plain-text financial accounting system with IFRS support,
    built on Event Sourcing / CQRS + DDD architecture.

license:            GPL-3.0-or-later
license-file:       LICENSE
author:             Yu Tokunaga
maintainer:         your@email.com
copyright:          2026 (c) Yu Tokunaga
category:           Finance, Accounting
build-type:         Simple
tested-with:        GHC == 9.8.2

-- ────────────────────────────────────────────────────────────────────────────
-- Common settings
-- ────────────────────────────────────────────────────────────────────────────
common common-options
    default-language:   GHC2021
    default-extensions:
        ImportQualifiedPost
        LambdaCase
        MultiWayIf
        OverloadedStrings
        OverloadedRecordDot
        RecordWildCards
        DerivingStrategies
        DeriveAnyClass
        DataKinds
        TypeFamilies
        GADTs
        ViewPatterns
        PatternSynonyms
        StrictData
    ghc-options:
        -Wall
        -Wcompat
        -Widentities
        -Wincomplete-record-updates
        -Wincomplete-uni-patterns
        -Wmissing-deriving-strategies
        -Wredundant-constraints
        -Wunused-packages
        -fhide-source-paths

common lib-deps
    build-depends:
        base >= 4.17 && < 5,
        text,
        time,
        mtl,
        transformers

