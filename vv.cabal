-- ────────────────────────────────────────────────────────────────────────────
-- Executable
-- ────────────────────────────────────────────────────────────────────────────
executable vv
    import:           common-options
    hs-source-dirs:   app
    main-is:          Main.hs
    other-modules:
        Adapter.Env
        Adapter.Controller.IAM
        Adapter.Presenter.IAM
        Adapter.View.Brick.App
    build-depends:
        base,
        vv:vv-internal,
        optparse-applicative >= 0.18 && < 1,
        brick >= 2.3 && < 3,
        vty >= 6.1 && < 7,
        stm,
        prettyprinter >= 1.7 && < 2,
        prettyprinter-ansi-terminal >= 1.1 && < 2,
        cassava >= 0.5 && < 1,
        text,
        effectful,
        mtl,
        containers
    ghc-options:
        -threaded
        -rtsopts
        -with-rtsopts=-N

-- ────────────────────────────────────────────────────────────────────────────
-- Test suite
-- ────────────────────────────────────────────────────────────────────────────
test-suite vv-test
    import:           common-options
    type:             exitcode-stdio-1.0
    hs-source-dirs:   test
    main-is:          Spec.hs
    other-modules:
        Domain.IAM.Spec
        Domain.IAM.UserSpec
        Domain.IAM.RoleSpec
        Domain.IAM.PermissionSpec
        Domain.Accounting.Spec
        Domain.Accounting.ChartOfAccountsSpec
        Domain.Accounting.FiscalPeriodSpec
        Domain.Accounting.JournalEntrySpec
        Domain.Accounting.ExchangeRateSpec
        Domain.IFRS.Spec
        Domain.IFRS.RevenueSpec
        Domain.IFRS.FinancialInstrumentSpec
        Domain.IFRS.LeaseSpec
        Support.Assert
        Support.IAM.Fixtures
        Support.Accounting.Fixtures
        Support.Text
    build-depends:
        base,
        vv:vv-internal,
        tasty >= 1.5 && < 2,
        tasty-hedgehog >= 1.4 && < 2,
        tasty-hunit >= 0.10 && < 1,
        hedgehog >= 1.4 && < 2,
        text,
        time,
        Decimal,
        safe-money,
        containers

-- ────────────────────────────────────────────────────────────────────────────
-- Benchmark
-- ────────────────────────────────────────────────────────────────────────────
benchmark vv-bench
    import:           common-options
    type:             exitcode-stdio-1.0
    hs-source-dirs:   bench
    main-is:          Main.hs
    build-depends:
        base,
        vv:vv-internal,
        tasty-bench >= 0.3 && < 1,
        deepseq >= 1.4 && < 2,
        time,
        text,
        containers
